# ----------------------------------------------------------------------------
# OrderVora — environment variables
# Copy to .env.local and fill in. .env.local is gitignored.
# ----------------------------------------------------------------------------

# Public (safe for the browser) ----------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only (never exposed to the browser) ---------------------------------
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Stripe — introduced in Phase 3, optional during Phase 0 --------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ----------------------------------------------------------------------------
# Edge Function runtime (set in the Supabase dashboard → Functions → Secrets,
# NOT in .env.local). Listed here for completeness.
# ----------------------------------------------------------------------------
# SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# SUPABASE_ANON_KEY=YOUR-ANON-KEY
# SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY   # also used by the seed
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# PLATFORM_FEE_BPS=0            # platform application fee in basis points (e.g. 500 = 5%)
# LOYALTY_POINTS_PER_UNIT=1     # loyalty points earned per currency unit of subtotal

# ----------------------------------------------------------------------------
# Seed script (set in your shell when running `npm run db:seed`)
# ----------------------------------------------------------------------------
# SUPABASE_URL=...              # same as above
# SUPABASE_SERVICE_ROLE_KEY=...
# SEED_SLUG=demo-deli           # override to create a second isolated tenant
