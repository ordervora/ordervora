# ----------------------------------------------------------------------------
# OrderVora — environment variables
#
# This file documents EVERY environment variable actually read by the
# codebase, grouped by which runtime reads it and where to get the value.
# Copy the "Next.js app" section to .env.local for local dev (.env.local is
# gitignored). The Edge Function and seed-script sections are NOT read from
# .env.local — see their own notes below.
# ----------------------------------------------------------------------------


# =============================================================================
# 1. Next.js app — read by config/env.ts. Set these in Vercel
#    (Project → Settings → Environment Variables) for Production/Preview,
#    and in .env.local for local dev.
# =============================================================================

# --- Public (NEXT_PUBLIC_* — inlined into the browser bundle) --------------

# [REQUIRED] Supabase project URL. Source: Supabase Dashboard → Project
# Settings → Data API → Project URL.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# [REQUIRED] Supabase anon (public) key. Source: Supabase Dashboard →
# Project Settings → API Keys → anon / public.
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# [REQUIRED] Canonical site origin, no trailing slash. Used to build OAuth
# and magic-link redirect URLs (app/auth/actions.ts). Source: your own
# domain — must exactly match what's in Vercel's Production domain and in
# Supabase Dashboard → Authentication → URL Configuration → Site URL /
# Redirect URLs, or sign-in will fail.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# [OPTIONAL] Stripe publishable key, used by the Payment Element on the
# client. Safe for the browser. Source: Stripe Dashboard → Developers →
# API keys → Publishable key. Leave empty until Stripe Connect (checkout)
# is wired up.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Server-only (never exposed to the browser; throws if read client-side) -

# [REQUIRED] Supabase service-role key — bypasses RLS. Source: Supabase
# Dashboard → Project Settings → API Keys → service_role. NEVER prefix
# with NEXT_PUBLIC_, never expose to the client, never commit a real value.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# [OPTIONAL] Stripe secret key, used server-side for checkout/payment
# intents. Source: Stripe Dashboard → Developers → API keys → Secret key.
STRIPE_SECRET_KEY=

# [OPTIONAL] Stripe webhook signing secret, used to verify webhook payload
# signatures. Source: Stripe Dashboard → Developers → Webhooks → (your
# endpoint) → Signing secret. Note: this Next.js-side var is currently
# read by config/env.ts (serverEnv.stripeWebhookSecret) but the actual
# Stripe webhook HANDLER lives in the Supabase Edge Function
# (supabase/functions/stripe-webhook), which reads its OWN copy of
# STRIPE_WEBHOOK_SECRET from Supabase Function secrets — see section 2.
# Set the same value in both places if both are in use.
STRIPE_WEBHOOK_SECRET=


# =============================================================================
# 2. Supabase Edge Functions (Deno runtime) — read via Deno.env.get(...) in
#    supabase/functions/**. Set with `supabase secrets set <KEY>=<value>`
#    or in Supabase Dashboard → Edge Functions → Manage secrets.
#    These are NOT read from .env.local / Vercel — they live entirely on
#    the Supabase side.
# =============================================================================

# [AUTO-INJECTED — do not set manually] SUPABASE_URL, SUPABASE_ANON_KEY,
# and SUPABASE_SERVICE_ROLE_KEY are reserved names that Supabase injects
# into every Edge Function automatically. `supabase secrets set` will
# reject attempts to overwrite a SUPABASE_-prefixed name. Used by
# supabase/functions/_shared/supabase.ts. Listed here only so the full
# variable surface is documented — there is nothing to configure.
# SUPABASE_URL=(auto-injected by Supabase)
# SUPABASE_ANON_KEY=(auto-injected by Supabase)
# SUPABASE_SERVICE_ROLE_KEY=(auto-injected by Supabase)

# [REQUIRED for Stripe-related functions] Stripe secret key. Read by
# supabase/functions/_shared/stripe.ts (used by checkout/refund-order).
# Source: same Stripe secret key as NEXT_PUBLIC section above. Must be
# set explicitly via `supabase secrets set STRIPE_SECRET_KEY=...`.
STRIPE_SECRET_KEY=

# [REQUIRED for the stripe-webhook function] Stripe webhook signing
# secret. Read by supabase/functions/stripe-webhook/index.ts. Source:
# Stripe Dashboard → Webhooks → your Supabase Function endpoint's signing
# secret (this is typically a DIFFERENT signing secret than the one used
# for any webhook endpoint defined elsewhere, since each endpoint gets its
# own secret).
STRIPE_WEBHOOK_SECRET=

# [OPTIONAL — defaults to 0] Platform application fee, in basis points
# (e.g. 500 = 5%), applied via Stripe Connect. Read by
# supabase/functions/_shared/stripe.ts. Source: your own business
# decision, not an external provider.
PLATFORM_FEE_BPS=0

# [OPTIONAL — defaults to 1] Loyalty points earned per currency unit of
# order subtotal. Read by supabase/functions/stripe-webhook/index.ts.
# Source: your own business decision.
LOYALTY_POINTS_PER_UNIT=1


# =============================================================================
# 3. Seed script (`npm run db:seed`, runs supabase/seed/index.ts via tsx on
#    plain Node — NOT the Edge runtime, so nothing here is auto-injected).
#    Set these in your shell before running the script; do not put real
#    secrets in this file.
# =============================================================================

# [REQUIRED] Same Supabase project URL as above. Read by
# supabase/seed/_shared.ts via requireEnv('SUPABASE_URL').
# SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# [REQUIRED] Same Supabase service-role key as above. Read by
# supabase/seed/_shared.ts via requireEnv('SUPABASE_SERVICE_ROLE_KEY').
# SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# [OPTIONAL — defaults to "demo-deli"] Slug for the seeded demo tenant.
# Override to create a second, isolated demo tenant without touching the
# first. Read by supabase/seed/_shared.ts.
# SEED_SLUG=demo-deli


